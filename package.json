		},
		"@nuxtjs/eslint-module": {
			"eslint-webpack-plugin": {
				"webpack": "^4.47.0"
			}
		},
		"@nuxtjs/stylelint-module": {
			"stylelint-webpack-plugin": {
				"stylelint": "^16.26.1",
				"webpack": "^4.47.0"
			},
			"webpack": "^4.47.0"
		},
		"@vue/component-compiler-utils": {
			"postcss": "^8.5.8"
		},
		"braces": "^3.0.3",
		"glob-parent": "^6.0.2",
		"jest-environment-jsdom": {
			"http-proxy-agent": "^7.0.2"
		},
		"json5": "^2.2.3",
		"micromatch": "^4.0.8",
		"minimatch": "^3.1.4",
		"nth-check": "^2.1.1",
